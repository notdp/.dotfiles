{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/zhenninglang/.dotfiles/scripts/hooks/context_capsule.py\" --event prompt",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ApplyPatch|Create|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/zhenninglang/.dotfiles/scripts/hooks/context_capsule.py\" --event post-tool",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ApplyPatch|Create|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/zhenninglang/.dotfiles/scripts/hooks/boundary_gate.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Execute",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/zhenninglang/.dotfiles/scripts/hooks/command_guard.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/zhenninglang/.dotfiles/scripts/hooks/stop_check.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
